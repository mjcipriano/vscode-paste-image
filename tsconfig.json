{
    "compilerOptions": {
        "module": "Node16",
        "target": "es2020",
        "outDir": "out",
        "sourceMap": true,
        "rootDir": ".",
        "lib": [
            "es2020"
        ],
        "moduleResolution": "node16",
        "types": [
            "node",
            "vscode"
        ],
        "strict": false,
        "skipLibCheck": true
    },
    "exclude": [
        "out",
        "node_modules",
        ".vscode-test"
    ]
}
